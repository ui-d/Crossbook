# Crossbook — runtime env vars. Copy to .env.local and fill in.

# === Clerk (auth) — required for `pnpm build` to succeed ===
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# === Supabase (DB) — required for /api/reconcile to work ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === Anthropic (Claude) ===
ANTHROPIC_API_KEY=

# === Stripe ($49/mo subscription) ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MONTHLY=

# === Resend (transactional + monthly digest) ===
RESEND_API_KEY=

# === App-level ===
NEXT_PUBLIC_APP_URL=https://crossbook.app

# Support inbox shown in footer + used as the from-address for transactional support email
SUPPORT_FROM_ADDRESS=support@crossbook.app

# === PostHog (product analytics) — optional; graceful no-op when unset ===
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# === DPA generator (Iubenda / Termly / Vanta) — needed at Day 17 ===
DPA_GENERATOR_API_KEY=

# === MCP servers (already present in your .env.local) ===
# SUPABASE_ACCESS_TOKEN=
# GITHUB_PERSONAL_ACCESS_TOKEN=
