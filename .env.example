# Crossbook — runtime env vars. Copy to .env.local and fill in.

# === Clerk (auth) — required for `pnpm build` to succeed ===
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# === Supabase (DB) — required for /api/reconcile to work ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === Anthropic (Claude) ===
ANTHROPIC_API_KEY=

# === Stripe ($49/mo subscription) ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MONTHLY=

# === Resend (transactional + monthly digest) ===
RESEND_API_KEY=
# From-address for the "your report is ready" + monthly digest emails.
# Must be a Resend-verified domain in production — until a domain is verified,
# Resend only delivers to the Resend account owner's own email address.
# REPORT_FROM_ADDRESS falls back to DIGEST_FROM_ADDRESS, then to onboarding@resend.dev.
REPORT_FROM_ADDRESS=
DIGEST_FROM_ADDRESS=

# === App-level ===
NEXT_PUBLIC_APP_URL=https://crossbook.app

# Support inbox shown in footer + used as the from-address for transactional support email
SUPPORT_FROM_ADDRESS=support@crossbook.app

# === PostHog (product analytics) — optional; graceful no-op when unset ===
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# === DPA generator (Iubenda / Termly / Vanta) — needed at Day 17 ===
DPA_GENERATOR_API_KEY=

# === Sentry (error tracking) — optional; full no-op when unset ===
# SENTRY_DSN gates server + edge (instrumentation.ts); NEXT_PUBLIC_SENTRY_DSN
# gates the browser (instrumentation-client.ts). Set both to the same DSN.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# === Operational kill-switch ===
# Set to 1/true to skip the Claude AI layer and force every conflict to
# MANUAL_REVIEW (use when Anthropic is rate-limited or down). /api/reconcile
# also degrades to this automatically if the Claude call throws.
DISABLE_AI_FALLBACK=

# === MCP servers (already present in your .env.local) ===
# SUPABASE_ACCESS_TOKEN=
# GITHUB_PERSONAL_ACCESS_TOKEN=
